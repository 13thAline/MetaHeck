# ============================================================
# Bank KYC/AML Audit Environment — Environment Variables
# ============================================================

# --- LLM Configuration (required for inference.py) ---
API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MODEL_NAME=gemini-2.5-flash

# Provide your Hugging Face or Gemini API key below
HF_TOKEN=your_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Docker Configuration ---
# Used by inference scripts to target the correct local container
LOCAL_IMAGE_NAME=kyc-audit-env

# --- Optional: Reproducibility ---
# Set a fixed seed to produce identical episodes across runs.
# Leave blank or unset for fully randomized episodes.
# EPISODE_SEED=42

# --- Optional: Trajectory Logging (for RL/DPO fine-tuning data) ---
# Directory where state-action-reward JSONL files are written per episode.
# Leave blank to disable trajectory logging.
# TRAJECTORY_LOG_DIR=./trajectories